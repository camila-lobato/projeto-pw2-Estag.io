<!-- Page Heading -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800">Bem-vindo(a) ao Estag.io</h1>
  <a href="/cadastro" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
    <i class="fas fa-user-plus fa-sm text-white-50"></i> Criar Conta
  </a>
</div>

<!-- Intro Card -->
<div class="card shadow mb-4">
  <div class="card-body">
    <h5 class="font-weight-bold text-primary mb-3">Conectando Talentos e Oportunidades</h5>
    <p class="mb-2">
      O <strong>Estag.io</strong> é uma plataforma web que conecta talentos em formação da área de
      <strong>Tecnologia da Informação</strong> com suas primeiras oportunidades no mercado.
    </p>
    <p>
      Aqui, <strong>empresas</strong> podem divulgar vagas de estágio e nível júnior, enquanto
      <strong>estudantes</strong> criam perfis detalhados com suas stacks, projetos e portfólio. Nosso
      objetivo é ser o ponto de partida mais eficiente e moderno para iniciar uma carreira em TI.
    </p>
  </div>
</div>

