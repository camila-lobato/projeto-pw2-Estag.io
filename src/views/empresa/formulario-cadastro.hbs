<h3>Estudantes cadastrados</h3>

<a href="/estudante/novo" class="btn btn-sm btn-primary mb-3">
  <i class="fas fa-plus"></i> Novo Estudante
</a>

{{#if success}}
  <div class="alert alert-success">
    {{#each success}}
      <p class="m-0">{{this}}</p>
    {{/each}}
  </div>
{{/if}}

{{#if error}}
  <div class="alert alert-danger">
    {{#each error}}
      <p class="m-0">{{this}}</p>
    {{/each}}
  </div>
{{/if}}

<table class="table table-bordered mt-3">
  <thead class="thead-light">
    <tr>
      <th>#</th>
      <th>Nome</th>
      <th>Email</th>
      <th>Curso</th>
      <th width="180">Ações</th>
    </tr>
  </thead>

  <tbody>
    {{#each lista}}
    <tr>
      <td>{{this.id}}</td>
      <td>{{this.nome}}</td>
      <td>{{this.email}}</td>
      <td>{{this.curso}}</td>
      <td>
        <a href="/estudante/{{this.id}}/editar" class="btn btn-sm btn-warning">Editar</a>
        <a href="/estudante/{{this.id}}/excluir" class="btn btn-sm btn-danger">Excluir</a>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>
